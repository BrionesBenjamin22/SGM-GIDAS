APP_ENV=production
SECRET_KEY=replace-with-secure-secret
JWT_SECRET=replace-with-secure-secret
REFRESH_SECRET=replace-with-secure-secret
JWT_ISSUER=auth-service
JWT_AUDIENCE=gidas-api
FRONTEND_URL=https://gidas.example.com
FRONTEND_URLS=https://gidas.example.com
DATABASE_URL=postgresql://gidas_user:replace-with-secure-password@db:5432/gidas_db
SQLALCHEMY_TRACK_MODIFICATIONS=False
JWT_EXPIRATION_MINUTES=60
RATELIMIT_STORAGE_URI=redis://redis:6379/0
RATELIMIT_DEFAULT=120 per minute
AUTH_LOGIN_LIMIT=10 per minute
AUTH_REFRESH_LIMIT=30 per minute
AUTH_REGISTER_LIMIT=5 per hour
AUTH_CHANGE_PASSWORD_LIMIT=10 per hour
EXPORT_LIMIT=10 per hour
SEARCH_LIMIT=30 per minute
SEARCH_MAX_QUERY_LENGTH=80
SEARCH_MAX_PER_PAGE=50
SEARCH_MAX_SCAN_PER_MODEL=300
POSTGRES_DB=gidas_db
POSTGRES_USER=gidas_user
POSTGRES_PASSWORD=replace-with-secure-password
