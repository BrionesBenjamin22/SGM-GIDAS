APP_ENV=production
SECRET_KEY=replace-with-secure-secret
JWT_SECRET=replace-with-secure-secret
REFRESH_SECRET=replace-with-secure-secret
FRONTEND_URL=https://gidas.example.com
FRONTEND_URLS=https://gidas.example.com
DATABASE_URL=postgresql://gidas_user:replace-with-secure-password@db:5432/gidas_db
SQLALCHEMY_TRACK_MODIFICATIONS=False
JWT_EXPIRATION_MINUTES=60
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=120 per minute
POSTGRES_DB=gidas_db
POSTGRES_USER=gidas_user
POSTGRES_PASSWORD=replace-with-secure-password
